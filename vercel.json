{
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/app.html", "dest": "/app.html" },
    { "src": "/keywords.html", "dest": "/keywords.html" },
    { "src": "/posts.html", "dest": "/posts.html" },
    { "src": "/revenue.html", "dest": "/revenue.html" },
    { "src": "/memo.html", "dest": "/memo.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
